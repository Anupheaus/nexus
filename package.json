{
  "name": "@anupheaus/nexus",
  "version": "0.0.6",
  "type": "module",
  "main": "./dist/server.js",
  "exports": {
    ".": {
      "node": {
        "types": "./dist/server.d.ts",
        "import": "./dist/server.js"
      },
      "browser": {
        "types": "./dist/client.d.ts",
        "import": "./dist/client.js"
      },
      "default": {
        "types": "./dist/common.d.ts",
        "import": "./dist/common.js"
      }
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./common": {
      "types": "./dist/common.d.ts",
      "import": "./dist/common.js"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/server.d.ts"
      ],
      "server": [
        "./dist/server.d.ts"
      ],
      "client": [
        "./dist/client.d.ts"
      ],
      "common": [
        "./dist/common.d.ts"
      ]
    }
  },
  "repository": "https://github.com/Anupheaus/nexus.git",
  "description": "socket-api",
  "author": "Anupheaus",
  "license": "Apache-2.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/",
    "access": "public"
  },
  "private": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "start": "webpack --mode development",
    "server": "webpack --mode development --name server",
    "client": "webpack --mode development --name client --profile",
    "test": "vitest run",
    "test:perf": "vitest run tests/perf/",
    "test-ci": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:pw": "playwright test"
  },
  "files": [
    "dist",
    "README.md",
    "docs",
    "agent.md"
  ],
  "typings": "./dist/server.d.ts",
  "dependencies": {
    "@anupheaus/common": "^0.1.34",
    "selfsigned-ca": "^2.0.1",
    "@anupheaus/react-ui": "^0.0.81",
    "axios": "^1.9.0",
    "dotenv": "^17.0.0",
    "jsonwebtoken": "^9.0.2",
    "jwt-decode": "^4.0.0",
    "koa": "^2.14.1",
    "koa-bodyparser": "^4.4.1",
    "koa-router": "^12.0.1",
    "luxon": "^3.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-toolbelt": "^9.6.0"
  },
  "peerDependencies": {
    "@aparajita/capacitor-biometric-auth": "^10.0.0",
    "@capacitor/preferences": "^6.0.0 || ^7.0.0",
    "socket.io": "^4.6.0 || ^4.7.0 || ^4.8.0",
    "socket.io-client": "^4.6.0 || ^4.7.0 || ^4.8.0"
  },
  "peerDependenciesMeta": {
    "@aparajita/capacitor-biometric-auth": {
      "optional": true
    },
    "@capacitor/preferences": {
      "optional": true
    }
  },
  "devDependencies": {
    "@aparajita/capacitor-biometric-auth": "^10.0.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/preferences": "^8.0.1",
    "@emotion/react": "^11.10.6",
    "@emotion/styled": "^11.10.6",
    "@mui/material": "^5.11.9",
    "@playwright/test": "^1.52.0",
    "@size-limit/preset-small-lib": "^12.0.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^14.2.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/koa": "^2.13.5",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/koa-router": "^7.4.8",
    "@types/koa-static": "^4.0.4",
    "@types/luxon": "^3.2.0",
    "@types/node": "^25.0.0",
    "@types/pouchdb": "^6.4.2",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^4.0.0",
    "browser-resolve": "^2.0.0",
    "buffer": "^6.0.3",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^8.19.0",
    "jsdom": "^24.0.0",
    "koa-pug": "^5.1.1",
    "koa-static": "^5.0.0",
    "nodemon-webpack-plugin": "^4.8.1",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "progress-webpack-plugin": "^1.0.16",
    "size-limit": "^12.0.0",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "socket.io-parser": "^4.2.4",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths-webpack-plugin": "^4.1.0",
    "tss-react": "^4.9.10",
    "tsup": "^8.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.3.3",
    "util": "^0.12.5",
    "vite": "^6.3.5",
    "vitest": "^4.0.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^7.0.0",
    "webpack-inject-plugin": "^1.5.5",
    "webpack-node-externals": "^3.0.0"
  },
  "size-limit": [
    {
      "path": "dist/server.js",
      "limit": "500 KB"
    },
    {
      "path": "dist/client.js",
      "limit": "500 KB"
    },
    {
      "path": "dist/common.js",
      "limit": "100 KB"
    }
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "csstype": "3.2.3",
      "@anupheaus/common": "file:../common",
      "webpack-inject-plugin>loader-utils": "1.4.2",
      "node-forge": "1.4.0",
      "@typescript-eslint/typescript-estree>minimatch": ">=9.0.7",
      "esbuild": ">=0.25.0",
      "ws": ">=8.20.1",
      "vitest>vite": ">=6.4.2",
      "vite-node>vite": ">=6.4.2"
    }
  }
}
